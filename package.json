{
  "name": "sysmonitor",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.0.15",
  "publisher": "LiChenxi",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lcx-0504/sysmonitor.git"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sysmonitor-container",
          "title": "%viewTitle%",
          "icon": "./icon.svg",
          "when": "remoteName"
        }
      ]
    },
    "views": {
      "sysmonitor-container": [
        {
          "type": "webview",
          "id": "sysmonitor.panel",
          "name": "%viewName%",
          "when": "remoteName"
        }
      ]
    },
    "commands": [
      {
        "command": "sysmonitor.openPanel",
        "title": "%cmdOpen%",
        "when": "remoteName"
      }
    ],
    "configuration": {
      "title": "System Monitor",
      "properties": {
        "sysmonitor.refreshInterval": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 30,
          "description": "Refresh interval in seconds"
        },
        "sysmonitor.statusBar": {
          "type": "object",
          "default": {
            "barEnabled": true,
            "alignment": "left",
            "priority": 10,
            "cpu": true,
            "ram": true,
            "net": "off",
            "ssh": false,
            "gpu": {
              "summary": true,
              "mode": "off",
              "cards": [],
              "firstN": 2,
              "metric": "both",
              "skipIdle": false
            }
          },
          "description": "Status bar display configuration"
        },
        "sysmonitor.disk": {
          "type": "object",
          "default": {
            "mountFilter": "default",
            "hideParentMounts": true
          },
          "description": "Disk monitoring settings"
        },
        "sysmonitor.display": {
          "type": "object",
          "default": {
            "charts": true,
            "sparkMinutes": 5
          },
          "description": "Display settings"
        }
      }
    }
  }
}